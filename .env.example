# =====================================================
# TripUy — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# Do NOT commit .env or .env.local.
# =====================================================

# --- Public (safe to expose to client) ---
NEXT_PUBLIC_APP_NAME=TripUy
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_ENABLE_DEBUG=false
NEXT_PUBLIC_DEFAULT_CURRENCY=IDR

# --- Database (server only) ---
DATABASE_URL=postgresql://user:password@localhost:5432/tripuy

# --- Auth (server only) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Upload (server only) ---
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# --- Email (server only) ---
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# --- Optional infra ---
REDIS_URL=
CRON_SECRET=
